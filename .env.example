# Telegram fallback (Telethon)
# Copy this file to .env and set real values.
# The scripts auto-load .env from this folder.

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Optional (default: tgseed_session)
TELEGRAM_SESSION=tgseed_session

# Optional timeout for Telethon bot file wait in seconds (default: 180)
TELEGRAM_TIMEOUT=180

# Optional timeout for manual Telegram Desktop watcher in seconds.
# Set 0 (or leave empty) to disable timeout for long downloads.
TELEGRAM_WATCH_TIMEOUT=0

# Optional Telethon chunk size in KB for Telegram media download (64-512, default: 512)
TELEGRAM_PART_SIZE_KB=512

# Optional Telegram Desktop downloads folder override for manual Telegram mode
# Default auto-check paths:
#   ~/Downloads/Telegram Desktop
#   ~/Downloads
TELEGRAM_DESKTOP_DOWNLOAD_DIR=

# Optional minimum size (MB) for auto-picking Telegram completed files.
# Helps ignore tiny side-files in Telegram temp folders.
TELEGRAM_MIN_PICK_MB=5

# Optional no-change window (seconds) before treating a Telegram file as complete.
# File is moved only after size+mtime stay unchanged for this long.
TELEGRAM_STABLE_SECONDS=15

# Optional near-limit window (MB): stability check starts only when current size
# is within this distance from expected size.
TELEGRAM_STABILITY_NEAR_MB=10

# Optional cold-start wait (seconds) before sending tg:// bot link
# after opening Telegram Desktop. Increase on slower systems.
TELEGRAM_COLD_START_DELAY=5

# Optional fraction of expected size required before auto-move (0.5-1.0).
# When expected size is known from DriveSeed, candidate must reach this fraction.
TELEGRAM_EXPECTED_SIZE_RATIO=0.95
